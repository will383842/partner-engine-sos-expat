APP_NAME="SOS-Expat Partner Engine"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://partner-engine.life-expat.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=pe-postgres
DB_PORT=5432
DB_DATABASE=partner_engine
DB_USERNAME=partner
DB_PASSWORD=

REDIS_CLIENT=predis
REDIS_HOST=pe-redis
REDIS_PASSWORD=
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# Firebase
FIREBASE_PROJECT_ID=sos-urgently-ac307
FIREBASE_CREDENTIALS_PATH=/var/www/html/storage/app/firebase-credentials.json

# Webhook security (shared secret with Firebase)
ENGINE_API_KEY=

# Email (Zoho SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtppro.zoho.eu
MAIL_PORT=465
MAIL_USERNAME=noreply@sos-expat.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@sos-expat.com
MAIL_FROM_NAME="SOS-Expat"

# Frontend URL (for invitation links)
FRONTEND_URL=https://www.sos-expat.com

# Telegram Engine (admin notifications)
TELEGRAM_ENGINE_URL=https://engine-telegram-sos-expat.life-expat.com
TELEGRAM_ENGINE_API_KEY=

# CORS
CORS_ALLOWED_ORIGINS=https://www.sos-expat.com,https://sos-expat.com,https://sos-call.sos-expat.com,https://admin.sos-expat.com

# ============================================================
# SOS-Call B2B (2026-04-24) — nouveaux secrets
# ============================================================

# Stripe — pour l'émission des factures B2B partenaires via Stripe Invoicing
# MÊME COMPTE STRIPE que l'existant (paiements univers A), mais clé à recopier ici
# pour que Laravel puisse créer les Invoice Stripe côté Partner Engine.
# La récupérer :
#   - Dashboard: https://dashboard.stripe.com/apikeys → "Reveal live key"
#   - OU depuis Firebase: firebase functions:secrets:access STRIPE_SECRET_KEY_LIVE
STRIPE_SECRET=sk_live_REPLACE_ME

# Webhook signing secret — DIFFÉRENT du webhook Firebase existant (cas 2 : isolation)
# Nouveau webhook dédié aux factures partenaires B2B, distinct du webhook
# subscriptions déjà en place sur Firebase.
# 1. Dashboard Stripe → Webhooks → "+ Add endpoint"
# 2. URL : https://partner-engine.sos-expat.com/api/webhooks/stripe/invoice-events
# 3. Events : invoice.paid, invoice.payment_failed, invoice.finalized
# 4. Copier le "Signing secret" qui s'affiche UNE FOIS (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Firebase Partner Bridge — appelée quand une facture partenaire est payée
# pour libérer les holds provider côté Firestore.
FIREBASE_PARTNER_BRIDGE_URL=https://us-central1-sos-urgently-ac307.cloudfunctions.net
FIREBASE_PARTNER_BRIDGE_API_KEY=${ENGINE_API_KEY}

# SOS-Call domains (pour emails et liens dans PDF factures)
SOS_CALL_PUBLIC_URL=https://sos-call.sos-expat.com
ADMIN_PUBLIC_URL=https://admin.sos-expat.com

# Sentry (optionnel — monitoring erreurs)
SENTRY_LARAVEL_DSN=
