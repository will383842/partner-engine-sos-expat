APP_NAME="SOS-Expat Partner Engine"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://partner-engine.life-expat.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=pe-postgres
DB_PORT=5432
DB_DATABASE=partner_engine
DB_USERNAME=partner
DB_PASSWORD=

REDIS_CLIENT=predis
REDIS_HOST=pe-redis
REDIS_PASSWORD=
REDIS_PORT=6379

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

# Firebase
FIREBASE_PROJECT_ID=sos-urgently-ac307
FIREBASE_CREDENTIALS_PATH=/var/www/html/storage/app/firebase-credentials.json

# Webhook security (shared secret with Firebase)
ENGINE_API_KEY=

# Email (Zoho SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtppro.zoho.eu
MAIL_PORT=465
MAIL_USERNAME=noreply@sos-expat.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@sos-expat.com
MAIL_FROM_NAME="SOS-Expat"

# Frontend URL (for invitation links)
FRONTEND_URL=https://www.sos-expat.com

# Telegram Engine (admin notifications)
TELEGRAM_ENGINE_URL=https://engine-telegram-sos-expat.life-expat.com
TELEGRAM_ENGINE_API_KEY=

# CORS
CORS_ALLOWED_ORIGINS=https://www.sos-expat.com,https://sos-expat.com
